<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>KindLedger Escalation Hub (Local)</title>
  <style>
    :root{
      --bg:#0e1217;           /* app background */
      --panel:#111827;        /* cards */
      --panel-soft:#0f172a;   /* softer panels */
      --muted:#94a3b8;        /* secondary text */
      --text:#e5e7eb;         /* primary text */
      --brand:#2563eb;        /* brand */
      --brand-2:#38bdf8;      /* accent */
      --ok:#16a34a;           /* success */
      --warn:#f59e0b;         /* warning */
      --bad:#ef4444;          /* danger */
      --chip:#1f2937;         /* chip bg */
      --border:#1f2937;       /* borders */
    }
    *{box-sizing:border-box}
    html,body{height:100%}
    body{
      margin:0;
      font-family:ui-sans-serif, system-ui, -apple-system, Segoe UI, Roboto, "Helvetica Neue", Arial, "Noto Sans", "Apple Color Emoji", "Segoe UI Emoji";
      background:linear-gradient(180deg, #0b1020, #0a0f1a 40%, #0a0e19 100%);
      color:var(--text);
    }
    a{color:var(--brand-2); text-decoration:none}
    a:hover{text-decoration:underline}

    /* Layout */
    .app{display:grid; grid-template-rows:64px 1fr; height:100%;}
    .topbar{
      display:flex; align-items:center; justify-content:space-between;
      padding:10px 16px; border-bottom:1px solid var(--border);
      background:linear-gradient(90deg, #0b1223, #0c1530);
      box-shadow:0 1px 0 rgba(255,255,255,0.03) inset, 0 10px 40px rgba(0,0,0,0.3);
    }
    .brand{display:flex; align-items:center; gap:12px}
    .logo{width:36px; height:36px; border-radius:10px; background:linear-gradient(135deg,#2563eb,#38bdf8); display:grid; place-items:center; font-weight:800}
    .logo span{color:white}
    .brand h1{margin:0; font-size:16px; letter-spacing:.4px; color:#dbeafe}

    .tabs{display:flex; gap:8px; flex-wrap:wrap}
    .tab{padding:8px 12px; border:1px solid var(--border); border-radius:10px; background:rgba(255,255,255,0.02); cursor:pointer; font-size:14px; color:#cbd5e1}
    .tab.active{background:linear-gradient(180deg,#111b33,#0c1326); border-color:#1e293b; color:#e2e8f0}

    .container{padding:18px; height:100%; overflow:auto}
    .panel{background:linear-gradient(180deg,#0c1222,#0a0f1c); border:1px solid var(--border); border-radius:14px; padding:14px}
    .grid{display:grid; gap:14px}
    .grid.cols-2{grid-template-columns:1fr 1fr}
    .grid.cols-3{grid-template-columns:repeat(3,1fr)}
    @media (max-width: 980px){ .grid.cols-2, .grid.cols-3{grid-template-columns:1fr} }

    .section-title{margin:0 0 10px 0; font-size:14px; color:#cbd5e1; display:flex; align-items:center; gap:8px}
    .chips{display:flex; gap:6px; flex-wrap:wrap}
    .chip{background:var(--chip); border:1px solid var(--border); padding:4px 8px; border-radius:999px; font-size:12px; color:#cbd5e1}

    /* Tables */
    table{width:100%; border-collapse:collapse}
    th, td{padding:10px 10px; text-align:left; border-bottom:1px solid var(--border)}
    th{color:#cbd5e1; font-weight:600; background:#0b1428}
    tbody tr:hover{background:rgba(255,255,255,0.02)}

    /* Forms */
    .form{display:grid; gap:10px}
    .row{display:grid; gap:10px; grid-template-columns:1fr 1fr}
    @media (max-width: 980px){ .row{grid-template-columns:1fr} }
    label{font-size:12px; color:#93a3b8}
    input, select, textarea{
      width:100%; padding:10px 12px; border-radius:10px; border:1px solid var(--border);
      background:#0b1223; color:var(--text); outline:none;
    }
    textarea{min-height:88px; resize:vertical}

    .btns{display:flex; gap:10px; flex-wrap:wrap}
    .btn{padding:10px 14px; border-radius:10px; border:1px solid #1f2937; background:#0d1a34; color:#e2e8f0; cursor:pointer}
    .btn:hover{filter:brightness(1.05)}
    .btn.primary{background:linear-gradient(180deg,#2563eb,#1d4ed8); border-color:#1d4ed8}
    .btn.ghost{background:#0c1222}
    .btn.warn{background:#331b06; border-color:#7c2d12; color:#fdba74}
    .btn.ok{background:#062b16; border-color:#14532d; color:#86efac}

    .kbd{font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; background:#0c1222; border:1px solid var(--border); border-radius:8px; padding:2px 6px; font-size:12px}

    .muted{color:var(--muted)}
    .right{display:flex; justify-content:flex-end}
    .sep{height:1px; background:var(--border); margin:10px 0}

    .pill{padding:2px 8px; border-radius:999px; border:1px solid var(--border); font-size:12px}
    .pill.open{background:#071a0f; color:#86efac; border-color:#14532d}
    .pill.hold{background:#1a1306; color:#fcd34d; border-color:#a16207}
    .pill.closed{background:#1a0b0b; color:#fca5a5; border-color:#7f1d1d}
  </style>
</head>
<body>
  <div class="app">
    <div class="topbar">
      <div class="brand">
        <div class="logo"><span>K</span></div>
        <h1>KindLedger — Escalation Hub (Local)</h1>
      </div>
      <div class="tabs" id="tabs">
        <button class="tab active" data-tab="queue">Queue</button>
        <button class="tab" data-tab="cases">Cases</button>
        <button class="tab" data-tab="touches">Touches</button>
        <button class="tab" data-tab="promises">Promises</button>
        <button class="tab" data-tab="data">Data</button>
        <button class="tab" data-tab="settings">Settings</button>
      </div>
    </div>

    <div class="container" id="screen-queue"></div>
    <div class="container" id="screen-cases" style="display:none"></div>
    <div class="container" id="screen-touches" style="display:none"></div>
    <div class="container" id="screen-promises" style="display:none"></div>
    <div class="container" id="screen-data" style="display:none"></div>
    <div class="container" id="screen-settings" style="display:none"></div>
  </div>

  <script>
  // ==========
  // Utilities
  // ==========
  const $ = sel => document.querySelector(sel);
  const $$ = sel => Array.from(document.querySelectorAll(sel));
  const fmtDate = d => d ? new Date(d).toISOString().slice(0,10) : '';
  const fmtDateTime = d => {
    if(!d) return ''; const x = new Date(d);
    const pad = n => String(n).padStart(2,'0');
    return `${x.getFullYear()}-${pad(x.getMonth()+1)}-${pad(x.getDate())} ${pad(x.getHours())}:${pad(x.getMinutes())}`;
  }
  const todayKey = () => fmtDate(new Date());
  const uid = p => `${p||'ID'}_${Date.now()}_${Math.random().toString(36).slice(2,8)}`;
  const toNum = v => (v===''||v==null||isNaN(Number(v))) ? 0 : Number(v);
  const parseDate = v => v ? new Date(v) : null;

  // ==========
  // Storage (localStorage)
  // ==========
  const store = {
    key: 'kl_local_hub_v1',
    get(){
      const raw = localStorage.getItem(this.key);
      if(!raw) return { cases:[], touches:[], promises:[], config:{ orgName:'', replyTo:'', owner:'' } };
      try { return JSON.parse(raw) } catch(e){ return { cases:[], touches:[], promises:[], config:{ orgName:'', replyTo:'', owner:'' } } }
    },
    set(data){ localStorage.setItem(this.key, JSON.stringify(data)); },
    wipe(){ localStorage.removeItem(this.key); }
  }

  let DB = store.get();

  // ==========
  // Data helpers
  // ==========
  function addCase(c){ c.id = c.id||uid('CASE'); c.createdAt = c.createdAt||new Date(); c.updatedAt = new Date(); DB.cases.push(c); save(); return c; }
  function updateCase(id, patch){ const c = DB.cases.find(x=>x.id===id); if(!c) return; Object.assign(c, patch, {updatedAt:new Date()}); save(); return c; }
  function addTouch(t){ t.id = t.id||uid('TOUCH'); t.createdAt = t.createdAt||new Date(); DB.touches.push(t); save(); return t; }
  function addPromise(p){ p.id = p.id||uid('PTP'); p.openedAt = p.openedAt||new Date(); DB.promises.push(p); save(); return p; }
  function updatePromise(id, patch){ const p = DB.promises.find(x=>x.id===id); if(!p) return; Object.assign(p, patch); save(); return p; }
  function caseById(id){ return DB.cases.find(x=>x.id===id); }
  function touchesForCase(id){ return DB.touches.filter(t=>t.caseId===id).sort((a,b)=> new Date(b.createdAt)-new Date(a.createdAt)); }
  function promisesForCase(id){ return DB.promises.filter(p=>p.caseId===id).sort((a,b)=> new Date(b.promisedDate)-new Date(a.promisedDate)); }
  function save(){ store.set(DB); renderActive(); }

  // Defaults for demo if empty
  if(DB.cases.length===0){
    const c1 = addCase({
      customerName:'Acme Ltd', customerEmail:'ap@acme.co.uk', customerPhone:'+44 20 7123 4567',
      invoiceNumbers:'INV-1001, INV-1010', amount:2500, priority:'High', status:'Open', owner:'Team',
      nextAction: fmtDate(new Date()), holdUntil:'', issueType:'Slow pay', driveFolder:''
    });
    addTouch({caseId:c1.id, when:fmtDateTime(new Date()), channel:'Email', outcome:'Sent L2', summary:'Sent consolidated reminder', nextActionDate: fmtDate(new Date())});
    addPromise({caseId:c1.id, promisedDate: fmtDate(new Date(Date.now()+3*86400000)), amount:1000, status:'Open', followUpDate: fmtDate(new Date(Date.now()+3*86400000)), notes:'Needs PO'});
  }

  // ==========
  // Queue logic
  // ==========
  function computeQueue(){
    const today = new Date(todayKey());

    const ptpDue = DB.promises.filter(p=> p.status==='Open' && p.promisedDate && new Date(p.promisedDate) <= today)
      .map(p=> ({ type:'PTP due', caseId:p.caseId, label:`Promise due ${p.promisedDate}`, weight:100, promised:p }));

    const touchesDue = DB.touches.filter(t=> t.nextActionDate && new Date(t.nextActionDate) <= today)
      .map(t=> ({ type:'Follow-up', caseId:t.caseId, label:`Next action ${t.nextActionDate}`, weight:80, touch:t }));

    const caseNext = DB.cases.filter(c=> c.status==='Open' && c.nextAction && new Date(c.nextAction) <= today && (!c.holdUntil || new Date(c.holdUntil) < today))
      .map(c=> ({ type:'Case action', caseId:c.id, label:`Next action ${c.nextAction}`, weight:60 }));

    const highValue = DB.cases.filter(c=> c.status==='Open' && toNum(c.amount) >= 2000 && (!c.holdUntil || new Date(c.holdUntil) < today))
      .map(c=> ({ type:'High £', caseId:c.id, label:`£${toNum(c.amount).toLocaleString('en-GB')}`, weight:40 }));

    const all = [...ptpDue, ...touchesDue, ...caseNext, ...highValue];
    all.sort((a,b)=> b.weight - a.weight);
    return all;
  }

  // ==========
  // Screens
  // ==========
  function renderQueue(){
    const el = $('#screen-queue');
    const q = computeQueue();
    const rows = q.map(item=>{
      const c = caseById(item.caseId)||{};
      const chipCls = item.type==='PTP due'?'ok': item.type==='High £'?'warn':'ghost';
      const statusPill = c.status==='Open'?'open': c.status==='On hold'?'hold':'closed';
      return `<tr>
        <td><span class="chip ${chipCls}">${item.type}</span></td>
        <td><b>${c.customerName||''}</b><div class="muted">${c.invoiceNumbers||''}</div></td>
        <td>£${toNum(c.amount).toLocaleString('en-GB')}</td>
        <td><span class="pill ${statusPill}">${c.status||''}</span></td>
        <td>${item.label}</td>
        <td class="right"><button class="btn" onclick="openCase('${c.id}')">Open</button></td>
      </tr>`
    }).join('') || `<tr><td colspan="6" class="muted" style="text-align:center; padding:20px">Nothing queued for today 🎉</td></tr>`;

    el.innerHTML = `
      <div class="grid cols-2">
        <div class="panel">
          <h3 class="section-title">Today's queue</h3>
          <table>
            <thead><tr><th>Type</th><th>Customer</th><th>Amount</th><th>Status</th><th>Reason</th><th></th></tr></thead>
            <tbody>${rows}</tbody>
          </table>
        </div>
        <div class="panel">
          <h3 class="section-title">Quick add — touch</h3>
          ${renderQuickTouchForm()}
          <div class="sep"></div>
          <h3 class="section-title">Quick add — case</h3>
          ${renderQuickCaseForm()}
        </div>
      </div>
    `;
  }

  function renderCases(){
    const el = $('#screen-cases');

    const rows = DB.cases.slice().sort((a,b)=> new Date(b.updatedAt)-new Date(a.updatedAt)).map(c=>{
      const statusPill = c.status==='Open'?'open': c.status==='On hold'?'hold':'closed';
      return `<tr>
        <td><b>${c.customerName}</b><div class="muted">${c.customerEmail||''}</div></td>
        <td>${c.invoiceNumbers||''}</td>
        <td>£${toNum(c.amount).toLocaleString('en-GB')}</td>
        <td>${c.priority||''}</td>
        <td><span class="pill ${statusPill}">${c.status||''}</span></td>
        <td>${c.nextAction?c.nextAction:''}</td>
        <td class="right"><button class="btn" onclick="openCase('${c.id}')">Open</button></td>
      </tr>`
    }).join('') || `<tr><td colspan="7" class="muted" style="text-align:center; padding:20px">No cases yet</td></tr>`

    el.innerHTML = `
      <div class="panel">
        <div class="row">
          <div>
            <h3 class="section-title">Cases</h3>
          </div>
          <div class="right">
            <button class="btn" onclick="newCaseModal()">New case</button>
          </div>
        </div>
        <table>
          <thead><tr><th>Customer</th><th>Invoices</th><th>Amount</th><th>Priority</th><th>Status</th><th>Next action</th><th></th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  function renderTouches(){
    const el = $('#screen-touches');
    const rows = DB.touches.slice().sort((a,b)=> new Date(b.createdAt)-new Date(a.createdAt)).map(t=>{
      const c = caseById(t.caseId)||{};
      return `<tr>
        <td>${fmtDateTime(t.when||t.createdAt)}</td>
        <td>${t.channel}</td>
        <td>${t.outcome||''}</td>
        <td>${c.customerName||''}<div class="muted">${c.invoiceNumbers||''}</div></td>
        <td>${t.summary||''}</td>
        <td>${t.nextActionDate||''}</td>
        <td class="right"><button class="btn" onclick="openCase('${t.caseId}')">Open</button></td>
      </tr>`
    }).join('') || `<tr><td colspan="7" class="muted" style="text-align:center; padding:20px">No touches logged yet</td></tr>`

    el.innerHTML = `
      <div class="panel">
        <h3 class="section-title">Touches (latest first)</h3>
        <table>
          <thead><tr><th>When</th><th>Channel</th><th>Outcome</th><th>Case</th><th>Summary</th><th>Next action</th><th></th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  function renderPromises(){
    const el = $('#screen-promises');
    const rows = DB.promises.slice().sort((a,b)=> new Date(a.promisedDate)-new Date(b.promisedDate)).map(p=>{
      const c = caseById(p.caseId)||{};
      const statusColor = p.status==='Open'?'ok': p.status==='Kept'?'open': p.status==='Broken'?'bad':'warn';
      return `<tr>
        <td>${fmtDate(p.openedAt)}</td>
        <td>${fmtDate(p.promisedDate)}</td>
        <td>£${toNum(p.amount).toLocaleString('en-GB')}</td>
        <td><span class="pill ${statusColor}">${p.status}</span></td>
        <td>${c.customerName||''}</td>
        <td>${p.followUpDate||''}</td>
        <td class="right">
          <button class="btn" onclick="markPromise('${p.id}','Kept')">Mark kept</button>
          <button class="btn warn" onclick="markPromise('${p.id}','Broken')">Mark broken</button>
        </td>
      </tr>`
    }).join('') || `<tr><td colspan="7" class="muted" style="text-align:center; padding:20px">No promises yet</td></tr>`

    el.innerHTML = `
      <div class="panel">
        <h3 class="section-title">Promises to Pay</h3>
        <table>
          <thead><tr><th>Opened</th><th>Promised date</th><th>Amount</th><th>Status</th><th>Case</th><th>Follow-up</th><th></th></tr></thead>
          <tbody>${rows}</tbody>
        </table>
      </div>
    `;
  }

  function renderData(){
    const el = $('#screen-data');
    el.innerHTML = `
      <div class="grid cols-2">
        <div class="panel">
          <h3 class="section-title">Export / Backup</h3>
          <div class="btns">
            <button class="btn" onclick="exportJSON()">Export JSON</button>
            <button class="btn" onclick="exportCSV('cases')">Export Cases CSV</button>
            <button class="btn" onclick="exportCSV('touches')">Export Touches CSV</button>
            <button class="btn" onclick="exportCSV('promises')">Export Promises CSV</button>
          </div>
          <p class="muted">Tip: export at end of day for backup. This app is single-user and stores data in your browser.</p>
        </div>
        <div class="panel">
          <h3 class="section-title">Import</h3>
          <input type="file" id="fileImport" accept="application/json,text/csv" />
          <div class="btns" style="margin-top:10px">
            <button class="btn" onclick="importFile()">Import selected file</button>
            <button class="btn warn" onclick="if(confirm('Wipe all local data?')){ DB={ cases:[], touches:[], promises:[], config: DB.config||{} }; save(); }">Wipe data</button>
          </div>
          <p class="muted">JSON import will replace your current dataset. CSV import can be added per table (see docs in code).</p>
        </div>
      </div>
    `;
  }

  function renderSettings(){
    const el = $('#screen-settings');
    const c = DB.config||{ orgName:'', replyTo:'', owner:'' };
    el.innerHTML = `
      <div class="panel">
        <h3 class="section-title">Settings</h3>
        <div class="form">
          <div class="row">
            <div><label>Organisation name</label><input id="setOrg" value="${c.orgName||''}" /></div>
            <div><label>Default reply-to email</label><input id="setReply" value="${c.replyTo||''}" /></div>
          </div>
          <div class="row">
            <div><label>Default owner</label><input id="setOwner" value="${c.owner||''}" /></div>
            <div><label>High value threshold (£)</label><input id="setHigh" value="${c.highValue||2000}" type="number" /></div>
          </div>
          <div class="btns">
            <button class="btn primary" onclick="saveSettings()">Save settings</button>
          </div>
          <p class="muted">These defaults are used when creating cases and computing the daily queue.</p>
        </div>
      </div>
    `;
  }

  // ==========
  // Case detail modal (inline renderer)
  // ==========
  function openCase(id){
    const c = caseById(id); if(!c) return alert('Case not found');
    const tList = touchesForCase(id).map(t=> `<tr><td>${fmtDateTime(t.when||t.createdAt)}</td><td>${t.channel}</td><td>${t.outcome||''}</td><td>${t.summary||''}</td><td>${t.nextActionDate||''}</td></tr>`).join('') || `<tr><td colspan="5" class="muted">No touches yet</td></tr>`
    const pList = promisesForCase(id).map(p=> `<tr><td>${fmtDate(p.openedAt)}</td><td>${fmtDate(p.promisedDate)}</td><td>£${toNum(p.amount).toLocaleString('en-GB')}</td><td>${p.status}</td><td>${p.followUpDate||''}</td></tr>`).join('') || `<tr><td colspan="5" class="muted">No promises yet</td></tr>`

    const html = `
      <div class="panel" style="max-width:1100px; margin:0 auto">
        <div class="row">
          <div>
            <h3 class="section-title">Case — ${c.customerName} <span class="muted">(${c.invoiceNumbers||''})</span></h3>
            <div class="chips">
              <span class="chip">ID: ${c.id}</span>
              <span class="chip">Amount £${toNum(c.amount).toLocaleString('en-GB')}</span>
              <span class="chip">Priority: ${c.priority||''}</span>
            </div>
          </div>
          <div class="right btns">
            <button class="btn" onclick="copyEmailSubject('${c.id}')">Copy email subject</button>
            <button class="btn ok" onclick="saveCaseEdits('${c.id}')">Save changes</button>
          </div>
        </div>
        <div class="sep"></div>
        <div class="form">
          <div class="row">
            <div><label>Customer name</label><input id="ce_name" value="${c.customerName||''}"></div>
            <div><label>Customer email</label><input id="ce_email" value="${c.customerEmail||''}"></div>
          </div>
          <div class="row">
            <div><label>Customer phone</label><input id="ce_phone" value="${c.customerPhone||''}"></div>
            <div><label>Drive folder URL</label><input id="ce_drive" value="${c.driveFolder||''}"></div>
          </div>
          <div class="row">
            <div><label>Invoices</label><input id="ce_invoices" value="${c.invoiceNumbers||''}"></div>
            <div><label>Amount (£)</label><input id="ce_amount" type="number" value="${toNum(c.amount)}"></div>
          </div>
          <div class="row">
            <div>
              <label>Status</label>
              <select id="ce_status">
                <option ${c.status==='Open'?'selected':''}>Open</option>
                <option ${c.status==='On hold'?'selected':''}>On hold</option>
                <option ${c.status==='Closed'?'selected':''}>Closed</option>
              </select>
            </div>
            <div>
              <label>Priority</label>
              <select id="ce_priority">
                <option ${c.priority==='High'?'selected':''}>High</option>
                <option ${c.priority==='Medium'?'selected':''}>Medium</option>
                <option ${c.priority==='Low'?'selected':''}>Low</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div><label>Next action (date)</label><input id="ce_next" type="date" value="${c.nextAction||''}"></div>
            <div><label>Hold until (date)</label><input id="ce_hold" type="date" value="${c.holdUntil||''}"></div>
          </div>
          <div class="row">
            <div><label>Issue type</label><input id="ce_issue" value="${c.issueType||''}"></div>
            <div><label>Owner</label><input id="ce_owner" value="${c.owner||''}"></div>
          </div>
        </div>

        <div class="sep"></div>
        <div class="grid cols-2">
          <div>
            <h4 class="section-title">Log touch</h4>
            ${renderTouchForm(c.id)}
          </div>
          <div>
            <h4 class="section-title">Promise to pay</h4>
            ${renderPromiseForm(c.id)}
          </div>
        </div>

        <div class="sep"></div>
        <div class="grid cols-2">
          <div>
            <h4 class="section-title">Touches</h4>
            <table><thead><tr><th>When</th><th>Channel</th><th>Outcome</th><th>Summary</th><th>Next</th></tr></thead><tbody>${tList}</tbody></table>
          </div>
          <div>
            <h4 class="section-title">Promises</h4>
