        <div class="row">
          <div><label>Status</label><select id="pp_status"><option>Open</option><option>Kept</option><option>Broken</option><option>Extended</option></select></div>
          <div><label>Follow-up date</label><input type="date" id="pp_follow" value="${fmtDate(new Date(Date.now()+2*86400000))}"></div>
        </div>
        <div><label>Notes</label><textarea id="pp_notes" placeholder="Any context"></textarea></div>
        <div class="btns right"><button class="btn ok" onclick="submitPromise('${caseId}')">Add promise</button></div>
      </div>`
  }
  function submitPromise(caseId){
    addPromise({ caseId, promisedDate: $('#pp_date').value, amount: toNum($('#pp_amt').value), status: $('#pp_status').value, followUpDate: $('#pp_follow').value, notes: $('#pp_notes').value });
    // Put case on hold until promised date
    if($('#pp_date').value){ updateCase(caseId, { holdUntil: $('#pp_date').value, nextAction: $('#pp_follow').value||$('#pp_date').value }); }
    alert('Promise recorded & case put on hold');
    hideOverlay();
