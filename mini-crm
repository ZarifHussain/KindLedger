  function markPromise(id, status){ updatePromise(id, { status }); renderPromises(); }

  // ==========
  // New case modal
  // ==========
  function newCaseModal(){
    const html = `
      <div class="panel" style="max-width:900px; margin:0 auto">
        <h3 class="section-title">New case</h3>
        ${renderQuickCaseForm()}
      </div>`;
    showOverlay(html);
  }

  // ==========
  // Overlay helper
  // ==========
  function showOverlay(html){
    let overlay = document.createElement('div');
    overlay.id='overlay';
    overlay.style.position='fixed'; overlay.style.inset='0'; overlay.style.background='rgba(8,12,24,.7)'; overlay.style.backdropFilter='blur(2px)'; overlay.style.zIndex='1000';
    overlay.innerHTML = `<div style="max-height:90%; overflow:auto; padding:24px; display:grid; place-items:start"><div style="width:100%">${html}
      <div class="right" style="margin-top:10px"><button class="btn" onclick="hideOverlay()">Close</button></div></div></div>`;
    document.body.appendChild(overlay);
  }
  function hideOverlay(){ const el=$('#overlay'); if(el) el.remove(); renderActive(); }

  // ==========
  // Export/Import
  // ==========
  function exportJSON(){
    const data = JSON.stringify(DB, null, 2);
    download('kindledger_hub_backup.json', data, 'application/json');
  }
  function exportCSV(kind){
    let rows=[], header=[];
    if(kind==='cases'){
      header = ['id','customerName','customerEmail','customerPhone','invoiceNumbers','amount','priority','status','nextAction','holdUntil','issueType','owner','createdAt','updatedAt','driveFolder'];
      rows = DB.cases.map(c=> header.map(h=> c[h]??''));
    } else if(kind==='touches'){
      header = ['id','caseId','when','channel','outcome','summary','nextActionDate','createdAt'];
      rows = DB.touches.map(t=> header.map(h=> t[h]??''));
    } else if(kind==='promises'){
      header = ['id','caseId','openedAt','promisedDate','amount','status','followUpDate','notes'];
      rows = DB.promises.map(p=> header.map(h=> p[h]??''));
    }
    const csv = [header.join(','), ...rows.map(r=> r.map(v=> `"${String(v).replace(/"/g,'""')}"`).join(','))].join('\n');
    download(`kindledger_${kind}.csv`, csv, 'text/csv');
  }
  function download(name, data, type){
    const blob = new Blob([data], {type});
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a'); a.href=url; a.download=name; a.click(); URL.revokeObjectURL(url);
  }
  async function importFile(){
    const f = $('#fileImport').files[0]; if(!f) return alert('Pick a file');
    const text = await f.text();
    if(f.type.includes('json')){
      try{ DB = JSON.parse(text); save(); alert('Imported JSON (replaced dataset).'); }catch(e){ alert('Bad JSON'); }
    } else {
      alert('CSV import not implemented in this demo. Export JSON from another machine and import here to migrate.');
    }
  }

  // ==========
  // Settings
  // ==========
  function saveSettings(){
    DB.config = DB.config||{};
    DB.config.orgName = $('#setOrg').value;
    DB.config.replyTo = $('#setReply').value;
    DB.config.owner   = $('#setOwner').value;
    DB.config.highValue = toNum($('#setHigh').value)||2000;
    save(); alert('Settings saved');
  }

  // ==========
  // Tab routing
  // ==========
  function setActive(tab){
    $$('#tabs .tab').forEach(b=> b.classList.toggle('active', b.dataset.tab===tab));
    ['queue','cases','touches','promises','data','settings'].forEach(t=>{
      const el = document.getElementById('screen-'+t);
      el.style.display = (t===tab)?'block':'none';
    });
    window.currentTab = tab; renderActive();
  }
  function renderActive(){
    switch(window.currentTab){
      case 'queue': return renderQueue();
      case 'cases': return renderCases();
      case 'touches': return renderTouches();
      case 'promises': return renderPromises();
      case 'data': return renderData();
      case 'settings': return renderSettings();
    }
  }
  $$('#tabs .tab').forEach(b=> b.addEventListener('click', ()=> setActive(b.dataset.tab)));
  setActive('queue');

  // ==========
  // Expose some funcs to window for onclick handlers
  // ==========
  Object.assign(window, { openCase, newCaseModal, saveCaseEdits, copyEmailSubject, submitQuickTouch, submitQuickCase, submitTouch, renderQueue, renderCases, renderPromises, markPromise, exportJSON, exportCSV, importFile, saveSettings, submitPromise, hideOverlay });
  </script>
